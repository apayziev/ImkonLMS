# === Application ===
APP_NAME="IMKON LMS"
ENVIRONMENT=local

# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5434
POSTGRES_DB=imkon_lms_db
# Pool tuning — bump if gunicorn workers grow.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# === Security ===
SECRET_KEY=change-me-in-production
# Prod: ".imkonschool.uz" (share refresh cookie across subdomains). Dev: leave empty.
COOKIE_DOMAIN=

# === First Superuser ===
FIRST_SUPERUSER_PHONE=+998901234567
FIRST_SUPERUSER_PASSWORD=changeme123
FIRST_SUPERUSER_DOCUMENT_ID=ADMIN000

# === CORS ===
CORS_ORIGINS_STR=http://localhost:5173

# === Payment Sync ===
PAYMENT_API_URL=https://pms.imkonschool.uz
PAYMENT_SYNC_API_KEY=change-me-in-production

# === TMS Integration ===
TMS_API_URL=http://localhost:8000
TMS_EMBED_API_KEY=change-me-in-production
TMS_ORIGIN=https://tms.imkonschool.uz

# === Backup ===
# Strong passphrase for gpg AES256 encryption of nightly DB dumps.
# CRITICAL: store offline — losing this means losing access to backups.
BACKUP_ENCRYPTION_KEY=change-me-strong-passphrase

# === Telegram (optional, for backup uploads) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Observability ===
# SENTRY_DSN empty = Sentry disabled. Set in prod.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO
# Prod: true (JSON for log aggregation). Dev: false (human-readable console).
LOG_JSON=false
